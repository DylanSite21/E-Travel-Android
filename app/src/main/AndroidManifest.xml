<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ETicketing"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ETicketing"> <!-- Tema Utama -->

        <!-- Launcher: LoginActivity sekarang di package .activities -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Daftarkan semua Activity lainnya dengan package yang benar -->
        <activity android:name=".activities.RegisterActivity" />
        <activity android:name=".activities.AdminActivity" />
        <activity android:name=".activities.PengelolaActivity" />
        <activity android:name=".activities.MainActivity" />

    </application>
</manifest>